{
  "name": "po-professional-tools",
  "displayName": "PO Professional Tools",
  "description": "Local PO assistant for project scanning, AI-backed PBI generation, and Azure DevOps sync.",
  "version": "0.1.4",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/ltnguyenJha/PO-Professional-Tools.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "icon": "resources/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:po-tools.openDashboard",
    "onCommand:po-tools.openPbiStudio",
    "onCommand:po-tools.openBulkBreakdown",
    "onView:po-tools.mainView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "po-tools",
          "title": "PO Professional Tools",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "po-tools": [
        {
          "id": "po-tools.mainView",
          "name": "PO Professional Tools"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "po-tools.mainView",
        "contents": "Welcome to **PO Professional Tools** 🚀\n\nScan your codebase, generate AI-backed backlog items, and sync directly to Azure DevOps.\n\n[$(dashboard) Open Dashboard](command:po-tools.openDashboard)\n\n[$(symbol-class) Open PBI Studio](command:po-tools.openPbiStudio)\n\n[$(list-unordered) Open Bulk Breakdown](command:po-tools.openBulkBreakdown)"
      }
    ],
    "commands": [
      {
        "command": "po-tools.openDashboard",
        "title": "PO Tools: Open Dashboard",
        "icon": "resources/icon.png"
      },
      {
        "command": "po-tools.openPbiStudio",
        "title": "PO Tools: Open PBI Studio"
      },
      {
        "command": "po-tools.openBulkBreakdown",
        "title": "PO Tools: Open Bulk Breakdown"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview && npm run build:copy-webview",
    "build:extension": "node build/esbuild.config.js",
    "build:webview": "npm --prefix webview-ui run build",
    "build:copy-webview": "node build/copy-webview.js",
    "watch": "node build/esbuild.config.js --watch",
    "watch:webview": "npm --prefix webview-ui run dev",
    "lint": "eslint src --ext .ts",
    "package": "npx @vscode/vsce package",
    "test": "jest --config jest.config.js",
    "test:backend": "jest --config jest.config.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.12.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "azure-devops-node-api": "^14.1.0",
    "jsonrepair": "^3.14.0"
  }
}
